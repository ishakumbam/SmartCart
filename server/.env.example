DATABASE_URL=
JWT_SECRET=
JWT_REFRESH_SECRET=
GOOGLE_CLIENT_ID=
# Optional — Google Cloud Vision (paid after free tier). If unset, OCR uses Tesseract.js (free, local).
GOOGLE_APPLICATION_CREDENTIALS=
# OCR: auto (Vision if credentials set, else Tesseract) | google | tesseract
OCR_ENGINE=auto
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
# Cloudflare R2 (S3-compatible). Omit for real AWS S3.
S3_ENDPOINT=
# Optional: public base URL if you use a custom domain for the bucket (else derived from S3_ENDPOINT)
S3_PUBLIC_URL=
REDIS_HOST=
REDIS_PORT=
# Optional — Flipp partner API; cron is disabled if unset
FLIPP_API_KEY=
EXPO_ACCESS_TOKEN=
PORT=3000
NODE_ENV=development
CORS_ORIGIN=*
